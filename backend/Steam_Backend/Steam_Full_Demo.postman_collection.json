              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const roles = json.data || [];",
                  "const admin = roles.find(x => x.name === 'admin');",
                  "const developer = roles.find(x => x.name === 'developer');",
                  "const user = roles.find(x => x.name === 'user');",
                  "if (admin) pm.environment.set('adminRoleId', admin.id);",
                  "if (developer) pm.environment.set('developerRoleId', developer.id);",
