                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);",
                  "if (data.userId) pm.environment.set('userId', data.userId);",
                  "if (Array.isArray(data.roles)) pm.environment.set('currentRoles', data.roles.join(','));",
