              <mat-form-field appearance="outline">\r
                <mat-label>Precio</mat-label>\r
                <input matInput type="number" min="0" step="0.01" formControlName="price" />\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Agregar DLC</button>\r
            </form>\r
\r
            <form [formGroup]="offerForm" (ngSubmit)="addOffer()" class="tool-card">\r
              <span>Oferta</span>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Descuento %</mat-label>\r
                <input matInput type="number" min="1" max="100" formControlName="discount" />\r
              </mat-form-field>\r
              <div class="form-row">\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Inicio</mat-label>\r
                  <input matInput type="date" formControlName="startDate" />\r
                </mat-form-field>\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Fin</mat-label>\r
                  <input matInput type="date" formControlName="endDate" />\r
                </mat-form-field>\r
              </div>\r
              <button mat-raised-button color="primary" type="submit">Publicar oferta</button>\r
            </form>\r
          </div>\r
\r
          @if (selectedGame(); as selected) {\r
            <section class="detail-strip">\r
              <article>\r
                <span>Logros</span>\r
                <strong>{{ selected.achievements.length }}</strong>\r
                @for (achievement of selected.achievements; track achievement.achievementId) {\r
                  <small>{{ achievement.achievementId }} | {{ achievement.name }}</small>\r
                } @empty {\r
                  <small>Sin logros</small>\r
                }\r
              </article>\r
              <article>\r
                <span>DLC</span>\r
                <strong>{{ selected.dlcs.length }}</strong>\r
                @for (dlc of selected.dlcs; track dlc.dlcId) {\r
                  <small>{{ dlc.name }} | {{ dlc.price | currency: 'USD' : 'symbol' : '1.0-2' }}</small>\r
                } @empty {\r
                  <small>Sin DLC</small>\r
                }\r
              </article>\r
              <article>\r
                <span>Ofertas</span>\r
                <strong>{{ selected.offers.length }}</strong>\r
                @for (offer of selected.offers; track offer.offerId) {\r
                  <small>{{ offer.discount }}% | {{ offer.startDate | date }} - {{ offer.endDate | date }}</small>\r
                } @empty {\r
                  <small>Sin ofertas</small>\r
                }\r
              </article>\r
            </section>\r
          }\r
        </section>\r
      }\r
\r
      @case ('store') {\r
        <section class="panel store-panel">\r
          <div class="panel-heading">\r
            <div>\r
              <span class="eyebrow">User store</span>\r
              <h3>Wishlist, compras y libreria</h3>\r
            </div>\r
            @if (playerLoading()) {\r
              <mat-spinner diameter="32"></mat-spinner>\r
            }\r
          </div>\r
\r
          <form [formGroup]="storeGameForm" class="store-actions">\r
            <mat-form-field appearance="outline">\r
              <mat-label>Selecciona juego</mat-label>\r
              <mat-select formControlName="gameId">\r
                @for (game of games(); track game.gameId) {\r
                  <mat-option [value]="game.gameId">\r
                    {{ game.title }}{{ isGameOwned(game.gameId) ? ' (adquirido)' : '' }}\r
                  </mat-option>\r
                }\r
              </mat-select>\r
            </mat-form-field>\r
            <button mat-raised-button color="primary" type="button" (click)="addWishlist()">Wishlist</button>\r
            <button\r
              mat-raised-button\r
              color="accent"\r
              type="button"\r
              (click)="purchaseGame()"\r
              [disabled]="!!storeGameForm.controls.gameId.value && isGameOwned(storeGameForm.controls.gameId.value)"\r
            >\r
              {{\r
                storeGameForm.controls.gameId.value && isGameOwned(storeGameForm.controls.gameId.value)\r
                  ? 'Ya adquirido'\r
                  : 'Comprar'\r
              }}\r
            </button>\r
          </form>\r
\r
          <div class="two-column">\r
            <article class="stack-panel">\r
              <h4>Wishlist</h4>\r
              @for (item of wishlist(); track item.wishlistId) {\r
                <div class="mini-row">\r
                  <div>\r
                    <strong>{{ item.game.title }}</strong>\r
                    <small>{{ item.addedAt | date }}</small>\r
                  </div>\r
                  <button mat-button color="warn" type="button" (click)="removeWishlist(item.game.gameId)">\r
                    Quitar\r
                  </button>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">Tu wishlist esta vacia.</p>\r
              }\r
            </article>\r
\r
            <article class="stack-panel">\r
              <h4>Libreria</h4>\r
              @for (item of library(); track item.libraryId) {\r
                <div class="mini-row">\r
                  <div>\r
                    <strong>{{ item.game.title }}</strong>\r
                    <small>{{ item.purchasePrice | currency: 'USD' : 'symbol' : '1.0-2' }}</small>\r
                  </div>\r
                  <div class="row-actions">\r
                    <button mat-stroked-button type="button" (click)="viewLibraryItem(item)">Ver detalle</button>\r
                    <button mat-raised-button color="accent" type="button" (click)="downloadAndStart(item)">\r
                      Descargar e Iniciar\r
                    </button>\r
                  </div>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">Todavia no hay compras.</p>\r
              }\r
            </article>\r
          </div>\r
        </section>\r
      }\r
\r
      @case ('community') {\r
        <section class="community-grid">\r
          <article class="panel">\r
            <div class="panel-heading">\r
              <div>\r
                <span class="eyebrow">Reviews</span>\r
                <h3>Opiniones y respuestas</h3>\r
              </div>\r
              <button mat-stroked-button type="button" (click)="loadReviewsForSelectedGame()">Filtrar</button>\r
            </div>\r
\r
            <form [formGroup]="reviewForm" (ngSubmit)="createReview()" class="compact-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>{{ isUserOnly() ? 'Juego adquirido' : 'Juego' }}</mat-label>\r
                <mat-select [formControl]="storeGameForm.controls.gameId">\r
                  @for (game of reviewableGames(); track game.gameId) {\r
                    <mat-option [value]="game.gameId">{{ game.title }}</mat-option>\r
                  }\r
                </mat-select>\r
              </mat-form-field>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Recomendacion</mat-label>\r
                <mat-select formControlName="isRecommended">\r
                  <mat-option [value]="true">Recomendado</mat-option>\r
                  <mat-option [value]="false">No recomendado</mat-option>\r
                </mat-select>\r
              </mat-form-field>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Comentario</mat-label>\r
                <textarea matInput rows="3" formControlName="comment"></textarea>\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Publicar review</button>\r
            </form>\r
\r
            <form [formGroup]="reviewAnswerForm" (ngSubmit)="answerReview()" class="inline-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>ID review</mat-label>\r
                <input matInput type="number" min="1" formControlName="reviewId" />\r
              </mat-form-field>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Respuesta</mat-label>\r
                <input matInput formControlName="comment" />\r
              </mat-form-field>\r
              <button mat-stroked-button type="submit">Responder</button>\r
            </form>\r
\r
            <div class="stack-list">\r
              @for (review of reviews(); track review.reviewId) {\r
                <article class="review-row">\r
                  <div>\r
                    <strong>#{{ review.reviewId }} | {{ review.username }}</strong>\r
                    <span [class.good]="review.isRecommended">\r
                      {{ review.isRecommended ? 'Recomendado' : 'No recomendado' }}\r
                    </span>\r
                    <p>{{ review.comment || 'Sin comentario' }}</p>\r
                    @for (answer of review.answers; track answer.reviewAnswerId) {\r
                      <small>Respuesta: {{ answer.comment }}</small>\r
                    }\r
                  </div>\r
                  <button mat-button color="warn" type="button" (click)="deleteReview(review.reviewId)">\r
                    Eliminar\r
                  </button>\r
                </article>\r
              } @empty {\r
                <p class="empty-inline">No hay reviews para mostrar.</p>\r
              }\r
            </div>\r
          </article>\r
\r
          <article class="panel">\r
            <span class="eyebrow">Sesiones</span>\r
            <h3>Juego activo</h3>\r
            <div class="quick-actions">\r
              <button mat-raised-button color="primary" type="button" (click)="startSession()">Iniciar sesion</button>\r
            </div>\r
\r
            <form [formGroup]="sessionEndForm" (ngSubmit)="endSession()" class="inline-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>ID sesion</mat-label>\r
                <input matInput type="number" min="1" formControlName="sessionId" />\r
              </mat-form-field>\r
              <button mat-stroked-button type="submit">Finalizar</button>\r
            </form>\r
\r
            <div class="stack-list">\r
              @for (session of sessions(); track session.sessionId) {\r
                <div class="mini-row">\r
                  <div>\r
                    <strong>#{{ session.sessionId }} | {{ session.gameTitle }}</strong>\r
                    <small>{{ session.durationMinutes }} min</small>\r
                  </div>\r
                  <span class="status-pill" [class.online]="!session.endTime">\r
                    {{ session.endTime ? 'cerrada' : 'activa' }}\r
                  </span>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">No hay sesiones registradas.</p>\r
              }\r
            </div>\r
          </article>\r
\r
          <article class="panel">\r
            <span class="eyebrow">Logros</span>\r
            <h3>Desbloqueos</h3>\r
            <form [formGroup]="achievementUnlockForm" (ngSubmit)="unlockAchievement()" class="inline-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>ID logro</mat-label>\r
                <input matInput type="number" min="1" formControlName="achievementId" />\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Desbloquear</button>\r
            </form>\r
\r
            <div class="stack-list">\r
              @for (achievement of achievements(); track achievement.userAchievementId) {\r
                <div class="mini-row">\r
                  <div>\r
                    <strong>{{ achievement.achievementName }}</strong>\r
                    <small>{{ achievement.gameTitle }} | {{ achievement.unlockedAt | date }}</small>\r
                  </div>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">No hay logros desbloqueados.</p>\r
              }\r
            </div>\r
          </article>\r
\r
          <article class="panel">\r
            <span class="eyebrow">Amigos</span>\r
            <h3>Red social</h3>\r
            <form [formGroup]="friendForm" (ngSubmit)="addFriend()" class="inline-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>ID usuario amigo</mat-label>\r
                <input matInput formControlName="friendId" />\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Agregar</button>\r
            </form>\r
\r
            <div class="stack-list">\r
              @for (friend of friends(); track friend.friendId) {\r
                <div class="mini-row">\r
                  <div>\r
                    <strong>{{ friend.username }}</strong>\r
                    <small>{{ friend.email }}</small>\r
                  </div>\r
                  <button mat-button color="warn" type="button" (click)="removeFriend(friend.friendId)">Quitar</button>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">No hay amigos agregados.</p>\r
              }\r
            </div>\r
          </article>\r
        </section>\r
      }\r
\r
      @case ('access') {\r
        <section class="panel access-panel">\r
          <div class="panel-heading">\r
            <div>\r
              <span class="eyebrow">Admin</span>\r
              <h3>Roles, permisos y usuarios</h3>\r
            </div>\r
            @if (accessLoading()) {\r
              <mat-spinner diameter="32"></mat-spinner>\r
            }\r
          </div>\r
\r
          <form [formGroup]="userSearchForm" class="inline-form" (ngSubmit)="loadAccess()">\r
            <mat-form-field appearance="outline">\r
              <mat-label>Buscar usuario</mat-label>\r
              <input matInput formControlName="search" />\r
            </mat-form-field>\r
            <button mat-stroked-button type="submit">Buscar</button>\r
          </form>\r
\r
          <form [formGroup]="roleAssignForm" (ngSubmit)="assignRole()" class="role-form">\r
            <mat-form-field appearance="outline">\r
              <mat-label>Usuario</mat-label>\r
              <mat-select formControlName="userId">\r
                @for (user of users(); track user.userId) {\r
                  <mat-option [value]="user.userId">{{ user.username }} | {{ user.email }}</mat-option>\r
                }\r
              </mat-select>\r
            </mat-form-field>\r
            <mat-form-field appearance="outline">\r
              <mat-label>Rol</mat-label>\r
              <mat-select formControlName="roleId">\r
                @for (role of roles(); track role.id) {\r
                  <mat-option [value]="role.id">{{ role.name }}</mat-option>\r
                }\r
              </mat-select>\r
            </mat-form-field>\r
            <button mat-raised-button color="primary" type="submit">Asignar rol</button>\r
          </form>\r
\r
          <div class="access-grid">\r
            <article class="stack-panel">\r
              <h4>Usuarios</h4>\r
              @for (user of users(); track user.userId) {\r
                <div class="user-row">\r
                  <div>\r
                    <strong>{{ user.username }}</strong>\r
                    <small>{{ user.email }}</small>\r
                    <small>{{ user.userId }}</small>\r
                  </div>\r
                  <div class="role-actions">\r
                    @for (role of user.roles; track role) {\r
                      <button type="button" class="role-pill" (click)="removeRole(user.userId, role)">\r
                        {{ role }} x\r
                      </button>\r
                    } @empty {\r
                      <span class="muted">sin rol</span>\r
                    }\r
                  </div>\r
                </div>\r
              } @empty {\r
                <p class="empty-inline">No hay usuarios para mostrar.</p>\r
              }\r
            </article>\r
\r
            <article class="stack-panel">\r
              <h4>Permisos</h4>\r
              <div class="permission-cloud">\r
                @for (permission of permissions(); track permission.id) {\r
                  <span>{{ permission.code }}</span>\r
                } @empty {\r
                  <p class="empty-inline">No hay permisos cargados.</p>\r
                }\r
              </div>\r
            </article>\r
          </div>\r
        </section>\r
      }\r
\r
      @case ('account') {\r
        <section class="account-grid">\r
          <article class="panel">\r
            <span class="eyebrow">Mi cuenta</span>\r
            <h3>Actualizar datos</h3>\r
            <form [formGroup]="accountForm" (ngSubmit)="updateAccount()" class="compact-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>UserName</mat-label>\r
                <input matInput formControlName="username" autocomplete="username" />\r
                @if (accountForm.controls.username.touched && accountForm.controls.username.hasError('required')) {\r
                  <mat-error>El UserName es obligatorio</mat-error>\r
                }\r
              </mat-form-field>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Email</mat-label>\r
                <input matInput type="email" formControlName="email" autocomplete="email" />\r
                @if (accountForm.controls.email.touched && accountForm.controls.email.hasError('email')) {\r
                  <mat-error>Ingresa un email valido</mat-error>\r
                }\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Guardar datos</button>\r
            </form>\r
\r
            <div class="account-actions">\r
              <button mat-stroked-button type="button" (click)="renewSession()">Renew token</button>\r
              <button mat-flat-button color="warn" type="button" (click)="deleteAccount()">\r
                Eliminar cuenta\r
              </button>\r
            </div>\r
          </article>\r
\r
          <article class="panel">\r
            <span class="eyebrow">Seguridad</span>\r
            <h3>Cambiar contrase\xC3\xB1a</h3>\r
            <form [formGroup]="changePasswordForm" (ngSubmit)="changePassword()" class="compact-form">\r
              <mat-form-field appearance="outline">\r
                <mat-label>Contrase\xC3\xB1a actual</mat-label>\r
                <input matInput type="password" formControlName="currentPassword" />\r
              </mat-form-field>\r
              <mat-form-field appearance="outline">\r
                <mat-label>Nueva contrase\xC3\xB1a</mat-label>\r
                <input matInput type="password" formControlName="newPassword" />\r
              </mat-form-field>\r
              <button mat-raised-button color="primary" type="submit">Cambiar</button>\r
            </form>\r
          </article>\r
\r
          @if (!isUserOnly()) {\r
            <article class="panel">\r
              <span class="eyebrow">Registro</span>\r
              <h3>Invitar y completar usuario</h3>\r
              <form [formGroup]="registerInitForm" (ngSubmit)="registerInit()" class="inline-form">\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Email</mat-label>\r
                  <input matInput type="email" formControlName="email" />\r
                </mat-form-field>\r
                <button mat-stroked-button type="submit">Enviar token</button>\r
              </form>\r
              <form [formGroup]="registerValidateForm" (ngSubmit)="registerValidate()" class="inline-form">\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Token</mat-label>\r
                  <input matInput formControlName="token" />\r
                </mat-form-field>\r
                <button mat-stroked-button type="submit">Validar</button>\r
              </form>\r
              <form [formGroup]="registerCompleteForm" (ngSubmit)="registerComplete()" class="compact-form">\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Token</mat-label>\r
                  <input matInput formControlName="token" />\r
                </mat-form-field>\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Email</mat-label>\r
                  <input matInput type="email" formControlName="email" />\r
                </mat-form-field>\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Username</mat-label>\r
                  <input matInput formControlName="username" />\r
                </mat-form-field>\r
                <mat-form-field appearance="outline">\r
                  <mat-label>Password</mat-label>\r
                  <input matInput type="password" formControlName="password" />\r
                </mat-form-field>\r
                <button mat-raised-button color="primary" type="submit">Completar registro</button>\r
              </form>\r
            </article>\r
          }\r
\r
        </section>\r
      }\r
    }\r
  </main>\r
</section>\r
\r
@if (selectedLibraryItem(); as item) {\r
  <div class="modal-backdrop" (click)="closeLibraryDetail()">\r
    <section class="library-detail-modal" (click)="$event.stopPropagation()">\r
      <button mat-button type="button" class="modal-close" (click)="closeLibraryDetail()">Cerrar</button>\r
\r
      @if (selectedLibraryGame()?.imageUrl || item.game.imageUrl) {\r
        <img\r
          class="library-cover"\r
          [src]="selectedLibraryGame()?.imageUrl || item.game.imageUrl"\r
          [alt]="item.game.title"\r
        />\r
      }\r
\r
      <div class="library-detail-body">\r
        <span class="eyebrow">Juego en biblioteca</span>\r
        <h2>{{ selectedLibraryGame()?.title || item.game.title }}</h2>\r
        <p>{{ selectedLibraryGame()?.description || item.game.description }}</p>\r
\r
        <div class="detail-stats">\r
          <article>\r
            <span>Creador</span>\r
            <strong>{{ selectedLibraryGame()?.developerName || item.game.developerName || 'Sin desarrollador' }}</strong>\r
          </article>\r
          <article>\r
            <span>Publisher</span>\r
            <strong>{{ selectedLibraryGame()?.publisherName || item.game.publisherName || 'Sin publisher' }}</strong>\r
          </article>\r
          <article>\r
            <span>Compra</span>\r
            <strong>{{ item.purchaseDate | date }}</strong>\r
          </article>\r
          <article>\r
            <span>Precio pagado</span>\r
            <strong>{{ item.purchasePrice | currency: 'USD' : 'symbol' : '1.0-2' }}</strong>\r
          </article>\r
        </div>\r
\r
        @if (selectedLibraryOffer(); as offer) {\r
          <div class="offer-card">\r
            <strong>{{ offer.discount }}% de descuento</strong>\r
            <span>Oferta desde {{ offer.startDate | date }} hasta {{ offer.endDate | date }}</span>\r
          </div>\r
        }\r
\r
        <mat-chip-set aria-label="Generos del juego">\r
          @for (genre of selectedLibraryGame()?.genres || item.game.genres; track genre) {\r
            <mat-chip>{{ genre }}</mat-chip>\r
          } @empty {\r
            <mat-chip>Sin genero</mat-chip>\r
          }\r
        </mat-chip-set>\r
\r
        <button mat-raised-button color="accent" type="button" (click)="downloadAndStart()">\r
          Descargar e Iniciar\r
        </button>\r
      </div>\r
    </section>\r
  </div>\r
}\r
\r
@if (deleteCandidate()) {\r
  <div class="modal-backdrop">\r
    <app-confirm-dialog [data]="deleteDialogData()" (closed)="confirmDelete($event)" />\r
